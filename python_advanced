    .next-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 16px rgba(245, 158, 11, 0.4); }

    @media (max-width: 768px) {
      header { padding: 80px 0 24px; }
      h1 { font-size: 1.6rem; margin-bottom: 12px; }
      header p { font-size: 0.85rem; }
      section { margin-bottom: 40px; }
      .section-title { font-size: 1.25rem; margin-bottom: 12px; }
      .card { padding: 16px; margin-bottom: 16px; }
      .demo-grid { grid-template-columns: 1fr; gap: 10px; }
      .code-box, .preview-box { padding: 12px; font-size: 0.8rem; border-radius: 8px; }
      .tip-box { padding: 12px; font-size: 0.8rem; }
      .next-btn { padding: 16px; font-size: 1rem; margin-top: 30px; }
    }
