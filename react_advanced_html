<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>React 심화 완벽 가이드 - DEV. 동아리</title>
  <style>
    :root {
      --bg-dark: #050f14;
      --bg-card: rgba(15, 30, 35, 0.6);
      --text-main: #f8fafc;
      --text-muted: #94a3b8;
      --accent: #06b6d4; /* React Cyan */
      --accent-soft: rgba(6, 182, 212, 0.15);
      --line: rgba(255, 255, 255, 0.08);
      --code-bg: #0d1117;
      --preview-bg: #ffffff;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background-color: var(--bg-dark);
      color: var(--text-main);
      font-family: "Pretendard Variable", "SUIT Variable", "Noto Sans KR", sans-serif;
      line-height: 1.6;
      overflow-x: hidden;
      scroll-behavior: smooth;
    }

    .bg-glow {
      position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: -1; pointer-events: none;
    }
    .bg-glow::before {
      content: ''; position: absolute; top: -20%; right: -10%; width: 60vw; height: 60vw;
      max-width: 800px; max-height: 800px;
      background: var(--accent); filter: blur(180px); opacity: 0.12; border-radius: 50%;
    }

    nav {
      position: fixed; top: 0; left: 0; right: 0; height: 50px;
      background: rgba(5, 15, 20, 0.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--line); z-index: 100;
      display: flex; align-items: center; padding: 0 20px;
    }
    .nav-logo { font-weight: 800; font-size: 1.1rem; color: var(--text-main); text-decoration: none; }
    .nav-logo span { color: var(--accent); }

    .container { max-width: 1000px; margin: 0 auto; padding: 0 20px; }

    header {
      padding: 100px 0 40px; text-align: center;
    }
    .kicker {
      display: inline-block; padding: 4px 12px; background: var(--accent-soft);
      color: var(--accent); border: 1px solid rgba(6, 182, 212, 0.3); border-radius: 999px;
      font-size: 0.85rem; font-weight: 700; margin-bottom: 16px; letter-spacing: 0.05em;
    }
    h1 { font-size: 3rem; font-weight: 900; line-height: 1.2; margin-bottom: 16px; word-break: keep-all; }
    header p { font-size: 1.1rem; color: var(--text-muted); word-break: keep-all; max-width: 700px; margin: 0 auto; }

    main { padding-bottom: 100px; }

    section { margin-bottom: 60px; scroll-margin-top: 70px; }
    
    .section-title {
      font-size: 1.7rem; font-weight: 800; margin-bottom: 16px;
      display: flex; align-items: center; gap: 10px;
    }
    .section-title::before { content: ''; display: block; width: 5px; height: 24px; background: var(--accent); border-radius: 4px; }
    
    .text-content { font-size: 1.05rem; color: #cbd5e1; margin-bottom: 20px; word-break: keep-all; line-height: 1.6; }

    .card {
      background: var(--bg-card); border: 1px solid var(--line); border-radius: 16px;
      padding: 24px; margin-bottom: 20px; backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    }
    .card h3 { font-size: 1.2rem; margin-bottom: 10px; color: var(--accent); }
    
    .demo-grid { display: grid; gap: 20px; margin-top: 16px; grid-template-columns: 1fr 1fr; }
    .demo-grid.full { grid-template-columns: 1fr; }

    .code-box, .preview-box {
      border-radius: 12px; padding: 20px; font-size: 0.95rem; overflow-x: auto;
    }
    .code-box {
      background: var(--code-bg); border: 1px solid #30363d; font-family: "D2Coding", monospace;
      color: #e6edf3; line-height: 1.5; white-space: pre-wrap; word-break: break-all;
    }
    /* React Syntax Highlighting */
    .kw { color: #ff7b72; } /* keyword */
    .fn { color: #d2a8ff; } /* function / hook */
    .tag { color: #7ee787; } /* JSX tag */
    .attr { color: #79c0ff; } /* JSX attr */
    .st { color: #a5d6ff; } /* string */
    .cm { color: #8b949e; } /* comment */
    .vr { color: #f2cc60; } /* variable in {} */

    .preview-box {
      background: var(--preview-bg); color: #111; border: 1px solid #e4e4e7;
      display: flex; flex-direction: column; justify-content: center; font-family: sans-serif;
    }
    
    .interactive-btn {
      background-color: #06b6d4; color: white; border: none; padding: 10px 16px; 
      border-radius: 8px; font-size: 1rem; cursor: pointer; transition: 0.2s; font-weight: bold;
    }
    .interactive-btn:hover { background-color: #0891b2; }

    .tip-box {
      background: rgba(6, 182, 212, 0.08); border-left: 4px solid var(--accent);
      padding: 16px; border-radius: 0 8px 8px 0; margin-top: 16px; font-size: 0.95rem; color: #cbd5e1;
    }
    .tip-box strong { color: var(--accent); display: block; margin-bottom: 6px; font-size: 1rem; }

    .next-btn {
      display: block; width: 100%; text-align: center; padding: 20px;
      background: linear-gradient(to right, #0891b2, #0369a1); color: #fff;
      text-decoration: none; font-size: 1.2rem; font-weight: 800; border-radius: 12px;
      transition: transform 0.2s, box-shadow 0.2s; margin-top: 50px;
    }
    .next-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 16px rgba(6, 182, 212, 0.4); }

    /* =========================================
       모바일 최적화 (768px 이하)
       ========================================= */
    @media (max-width: 768px) {
      header { padding: 80px 0 24px; }
      h1 { font-size: 1.6rem; margin-bottom: 12px; }
      header p { font-size: 0.85rem; }
      section { margin-bottom: 40px; }
      .section-title { font-size: 1.25rem; margin-bottom: 12px; }
      .section-title::before { height: 18px; }
      .text-content { font-size: 0.85rem; margin-bottom: 12px; }
      .card { padding: 16px; margin-bottom: 16px; }
      .card h3 { font-size: 1rem; margin-bottom: 8px; }
      .demo-grid { grid-template-columns: 1fr; gap: 10px; margin-top: 10px; }
      .code-box, .preview-box { padding: 12px; font-size: 0.8rem; border-radius: 8px; }
      .tip-box { padding: 12px; font-size: 0.8rem; }
      .tip-box strong { font-size: 0.85rem; margin-bottom: 4px; }
      .next-btn { padding: 16px; font-size: 1rem; margin-top: 30px; }
    }
  </style>
</head>
<body>
  <div class="bg-glow"></div>

  <nav>
    <a href="index.html" class="nav-logo">DEV. <span>동아리</span></a>
  </nav>

  <div class="container">
    <header>
      <div class="kicker">Chapter 4-2. 모던 프론트엔드의 정점</div>
      <h1>React 심화 (Advanced)</h1>
      <p>useState만 안다고 리액트를 다 아는 것이 아닙니다. 렌더링 최적화, 컴포넌트의 생명주기, 그리고 프롭스 지옥을 탈출하는 전역 상태 관리까지 마스터해 봅니다.</p>
    </header>

    <main>
      <section>
        <h2 class="section-title">1. useEffect 와 Side Effect</h2>
        <p class="text-content">리액트 컴포넌트는 오직 '화면을 그리는 일(렌더링)'만 집중해야 합니다. 화면을 다 그린 <strong>이후에 발생해야 하는 일(서버에서 데이터 가져오기, 타이머 설정 등)</strong>을 Side Effect라고 부르며, 이를 처리하는 훅이 <code>useEffect</code>입니다.</p>
        
        <div class="card">
          <h3>의존성 배열 (Dependency Array)</h3>
          <p class="text-content">useEffect의 두 번째 인자인 배열 <code>[]</code>에 무엇을 넣느냐에 따라 실행 타이밍이 결정됩니다.</p>
          <div class="demo-grid full">
            <div class="code-box">
<span class="kw">import</span> { useState, useEffect } <span class="kw">from</span> <span class="st">'react'</span>;

<span class="kw">function</span> <span class="fn">UserProfile</span>({ <span class="vr">userId</span> }) {
  <span class="kw">const</span> [user, setUser] = <span class="fn">useState</span>(<span class="kw">null</span>);

  <span class="fn">useEffect</span>(() <span class="kw">=&gt;</span> {
    <span class="cm">// 1. 화면이 처음 마운트(등장)되거나,</span>
    <span class="cm">// 2. userId 값이 바뀔 때만 이 코드가 실행됩니다.</span>
    console.<span class="fn">log</span>(<span class="st">"서버에 데이터 요청 중..."</span>);
    
    <span class="fn">fetch</span>(<span class="st">`/api/users/`</span> + <span class="vr">userId</span>)
      .<span class="fn">then</span>(<span class="vr">res</span> <span class="kw">=&gt;</span> <span class="vr">res</span>.<span class="fn">json</span>())
      .<span class="fn">then</span>(<span class="vr">data</span> <span class="kw">=&gt;</span> <span class="fn">setUser</span>(<span class="vr">data</span>));

    <span class="cm">// 3. 언마운트(사라질 때) 혹은 다음 이펙트 실행 전 정리(Clean-up)</span>
    <span class="kw">return</span> () <span class="kw">=&gt;</span> {
      console.<span class="fn">log</span>(<span class="st">"이전 요청 취소 완료!"</span>);
    };
  }, [<span class="vr">userId</span>]); <span class="cm">// &lt;-- 요 녀석이 의존성 배열입니다.</span>

  <span class="kw">if</span> (!user) <span class="kw">return</span> <span class="tag">&lt;div&gt;</span>로딩 중...<span class="tag">&lt;/div&gt;</span>;
  <span class="kw">return</span> <span class="tag">&lt;div&gt;</span><span class="vr">{user.name}</span>님 환영합니다!<span class="tag">&lt;/div&gt;</span>;
}
            </div>
          </div>
          <div class="tip-box">
            <strong>⚠️ 무한 루프(Infinite Loop) 주의</strong>
            만약 의존성 배열 <code>[]</code>을 빼먹으면 컴포넌트가 렌더링될 때마다 매번 실행됩니다. useEffect 안에서 <code>setState</code>를 했는데 배열이 없다면? 무한으로 화면을 다시 그리며 브라우저가 뻗어버립니다.
          </div>
        </div>
      </section>

      <section>
        <h2 class="section-title">2. useRef 로 DOM 직접 만지기</h2>
        <p class="text-content">리액트는 우리가 직접 DOM(HTML 요소)을 만지는 것을 권장하지 않습니다. 하지만 '입력창에 커서 맞추기', '스크롤 위치 기억하기' 등 꼭 DOM에 접근해야 할 때 <code>useRef</code>를 사용합니다.</p>

        <div class="card">
          <div class="demo-grid">
            <div class="code-box">
<span class="kw">import</span> { useRef } <span class="kw">from</span> <span class="st">'react'</span>;

<span class="kw">function</span> <span class="fn">FocusInput</span>() {
  <span class="cm">// 1. 빈 박스(ref)를 하나 만듭니다.</span>
  <span class="kw">const</span> inputRef = <span class="fn">useRef</span>(<span class="kw">null</span>);

  <span class="kw">const</span> <span class="fn">handleFocus</span> = () <span class="kw">=&gt;</span> {
    <span class="cm">// 3. inputRef.current에 담긴 실제 DOM 요소에 접근!</span>
    <span class="vr">inputRef.current</span>.<span class="fn">focus</span>();
  };

  <span class="kw">return</span> (
    <span class="tag">&lt;div&gt;</span>
      <span class="cm">{/* 2. ref 속성을 통해 input 요소를 박스에 연결 */}</span>
      <span class="tag">&lt;input</span> <span class="attr">ref</span>=<span class="vr">{inputRef}</span> <span class="attr">placeholder</span>=<span class="st">"여기를 보세요"</span> <span class="tag">/&gt;</span>
      <span class="tag">&lt;button</span> <span class="attr">onClick</span>=<span class="vr">{handleFocus}</span><span class="tag">&gt;</span>
        커서 이동시키기
      <span class="tag">&lt;/button&gt;</span>
    <span class="tag">&lt;/div&gt;</span>
  );
}
            </div>
            <div class="preview-box" style="align-items: center; background: #f8fafc;">
              <input id="demoRefInput" placeholder="여기를 보세요" style="padding: 10px; border: 2px solid #ccc; border-radius: 6px; margin-bottom: 10px; outline: none; width: 80%;">
              <button class="interactive-btn" onclick="document.getElementById('demoRefInput').focus(); document.getElementById('demoRefInput').style.borderColor = '#06b6d4';">커서 이동시키기</button>
            </div>
          </div>
          <div class="tip-box">
            <strong>💡 화면을 다시 그리지 않는 저장소</strong>
            <code>useState</code>는 값이 바뀌면 컴포넌트가 처음부터 다시 그려지지만, <code>useRef</code>에 저장한 값은 바뀌어도 <strong>화면이 다시 렌더링되지 않습니다.</strong> 화면 변화와 상관없이 기억해야 할 값이 있다면 useRef가 제격입니다.
          </div>
        </div>
      </section>

      <section>
        <h2 class="section-title">3. Context API (프롭스 지옥 탈출)</h2>
        <p class="text-content">부모가 까마득히 먼 증손자 컴포넌트에게 데이터를 주기 위해, 중간에 있는 애꿎은 컴포넌트들에게 계속 props를 넘겨야 하는 현상을 <strong>프롭스 드릴링(Props Drilling)</strong>이라고 합니다. 이를 해결하는 것이 <strong>전역 상태 관리</strong>입니다.</p>

        <div class="card">
          <div class="demo-grid full">
            <div class="code-box">
<span class="kw">import</span> { createContext, useContext } <span class="kw">from</span> <span class="st">'react'</span>;

<span class="cm">// 1. 데이터를 담을 컨텍스트(우체통) 생성</span>
<span class="kw">const</span> ThemeContext = <span class="fn">createContext</span>(<span class="st">"light"</span>);

<span class="kw">function</span> <span class="fn">App</span>() {
  <span class="kw">return</span> (
    <span class="cm">// 2. Provider(우체국)로 하위 요소들을 감싸고 데이터(value) 제공</span>
    <span class="tag">&lt;ThemeContext.Provider</span> <span class="attr">value</span>=<span class="st">"dark"</span><span class="tag">&gt;</span>
      <span class="tag">&lt;Layout</span> <span class="tag">/&gt;</span> <span class="cm">{/* 중간 컴포넌트는 아무것도 전달하지 않음! */}</span>
    <span class="tag">&lt;/ThemeContext.Provider&gt;</span>
  );
}

<span class="kw">function</span> <span class="fn">Layout</span>() {
  <span class="kw">return</span> <span class="tag">&lt;Header</span> <span class="tag">/&gt;</span>;
}

<span class="kw">function</span> <span class="fn">Header</span>() {
  <span class="cm">// 3. 저 멀리 있는 자식 컴포넌트가 useContext로 우체통에서 값을 쏙 빼옴</span>
  <span class="kw">const</span> theme = <span class="fn">useContext</span>(ThemeContext);
  
  <span class="kw">return</span> <span class="tag">&lt;h1&gt;</span>현재 테마는 <span class="vr">{theme}</span> 입니다.<span class="tag">&lt;/h1&gt;</span>;
}
            </div>
          </div>
          <div class="tip-box">
            <strong>💡 Redux, Zustand와의 관계</strong>
            Context API는 리액트 내장 기능이라 좋지만, 상태가 바뀔 때마다 하위 컴포넌트 전체가 다시 렌더링되는 성능 문제가 있습니다. 그래서 실무에서는 <b>Zustand, Redux, Recoil</b> 같은 외부 상태 관리 라이브러리를 훨씬 더 많이 사용합니다.
          </div>
        </div>
      </section>

      <section>
        <h2 class="section-title">4. Custom Hook (나만의 훅 만들기)</h2>
        <p class="text-content">useState나 useEffect 같은 로직이 여러 컴포넌트에서 중복된다면? 그 로직만 쏙 빼서 <strong><code>use</code>로 시작하는 나만의 함수</strong>를 만들 수 있습니다. 이것이 커스텀 훅입니다.</p>

        <div class="card">
          <h3>창 크기를 감지하는 useWindowSize 훅</h3>
          <div class="demo-grid full">
            <div class="code-box">
<span class="cm">// 로직만 따로 빼서 만든 나만의 훅</span>
<span class="kw">function</span> <span class="fn">useWindowSize</span>() {
  <span class="kw">const</span> [size, setSize] = <span class="fn">useState</span>({
    <span class="vr">width</span>: window.innerWidth,
    <span class="vr">height</span>: window.innerHeight
  });

  <span class="fn">useEffect</span>(() <span class="kw">=&gt;</span> {
    <span class="kw">const</span> <span class="fn">handleResize</span> = () <span class="kw">=&gt;</span> <span class="fn">setSize</span>({ <span class="vr">width</span>: window.innerWidth, <span class="vr">height</span>: window.innerHeight });
    window.<span class="fn">addEventListener</span>(<span class="st">'resize'</span>, handleResize);
    <span class="kw">return</span> () <span class="kw">=&gt;</span> window.<span class="fn">removeEventListener</span>(<span class="st">'resize'</span>, handleResize);
  }, []);

  <span class="kw">return</span> size; <span class="cm">// 데이터만 반환! 화면을 그리지 않음.</span>
}

<span class="cm">// 실제 컴포넌트에서는 이렇게 깔끔하게 가져다 씁니다.</span>
<span class="kw">function</span> <span class="fn">App</span>() {
  <span class="kw">const</span> { width, height } = <span class="fn">useWindowSize</span>();
  <span class="kw">return</span> <span class="tag">&lt;div&gt;</span>화면 너비: <span class="vr">{width}</span>px<span class="tag">&lt;/div&gt;</span>;
}
            </div>
          </div>
        </div>
      </section>

      <section>
        <h2 class="section-title">5. 렌더링 최적화 (memo, useMemo, useCallback)</h2>
        <p class="text-content">리액트는 부모 컴포넌트가 다시 그려지면, 아무 잘못 없는 자식 컴포넌트들도 모조리 처음부터 다시 그립니다. 화면이 복잡해질수록 렉이 걸리는 원인이 됩니다.</p>

        <div class="card">
          <div class="demo-grid full">
            <div class="code-box">
<span class="kw">import</span> { memo, useMemo, useCallback } <span class="kw">from</span> <span class="st">'react'</span>;

<span class="cm">// 1. React.memo: "내 Props가 바뀌지 않으면 나를 다시 그리지 마!"</span>
<span class="kw">const</span> ChildComponent = <span class="fn">memo</span>(({ <span class="vr">data</span>, <span class="vr">onClick</span> }) <span class="kw">=&gt;</span> {
  console.<span class="fn">log</span>(<span class="st">"자식 컴포넌트 렌더링 됨!"</span>);
  <span class="kw">return</span> <span class="tag">&lt;button</span> <span class="attr">onClick</span>=<span class="vr">{onClick}</span><span class="tag">&gt;</span><span class="vr">{data}</span><span class="tag">&lt;/button&gt;</span>;
});

<span class="kw">function</span> <span class="fn">Parent</span>() {
  <span class="kw">const</span> [count, setCount] = <span class="fn">useState</span>(0);

  <span class="cm">// 2. useMemo: 계산이 오래 걸리는 '값'을 캐싱(저장)해둠</span>
  <span class="kw">const</span> hardData = <span class="fn">useMemo</span>(() <span class="kw">=&gt;</span> {
    <span class="kw">return</span> <span class="st">"어마어마하게 복잡한 연산의 결과"</span>;
  }, []); <span class="cm">// 의존성 배열 값이 안 바뀌면 재사용</span>

  <span class="cm">// 3. useCallback: 함수 자체를 캐싱해둠</span>
  <span class="cm">// 부모가 재렌더링될 때마다 함수가 새로 태어나는 것을 막아줌</span>
  <span class="kw">const</span> handleClick = <span class="fn">useCallback</span>(() <span class="kw">=&gt;</span> {
    console.<span class="fn">log</span>(<span class="st">"클릭됨!"</span>);
  }, []);

  <span class="kw">return</span> (
    <span class="tag">&lt;div&gt;</span>
      <span class="tag">&lt;button</span> <span class="attr">onClick</span>=<span class="vr">{() <span class="kw">=&gt;</span> <span class="fn">setCount</span>(count + 1)}</span><span class="tag">&gt;</span>카운트: <span class="vr">{count}</span><span class="tag">&lt;/button&gt;</span>
      
      <span class="cm">{/* 부모의 count가 올라도 ChildComponent는 재렌더링되지 않음! */}</span>
      <span class="tag">&lt;ChildComponent</span> <span class="attr">data</span>=<span class="vr">{hardData}</span> <span class="attr">onClick</span>=<span class="vr">{handleClick}</span> <span class="tag">/&gt;</span>
    <span class="tag">&lt;/div&gt;</span>
  );
}
            </div>
          </div>
          <div class="tip-box">
            <strong>⚠️ 무분별한 최적화는 독입니다</strong>
            <code>useMemo</code>와 <code>useCallback</code>을 사용하면 그 값을 기억하기 위해 메모리를 추가로 사용합니다. 너무 가벼운 연산이나 단순한 함수까지 다 감싸면 오히려 메모리 낭비로 성능이 더 떨어집니다. 정말로 렌더링에 오래 걸리는 곳에만 적절히 써주세요!
