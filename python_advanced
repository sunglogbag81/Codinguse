    }

    .bg-glow {
      position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: -1; pointer-events: none;
    }
    .bg-glow::before {
      content: ''; position: absolute; top: -20%; left: -10%; width: 60vw; height: 60vw;
      max-width: 800px; max-height: 800px;
      background: var(--accent); filter: blur(180px); opacity: 0.12; border-radius: 50%;
    }

    nav {
      position: fixed; top: 0; left: 0; right: 0; height: 50px;
      background: rgba(10, 8, 4, 0.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
